# vllm-greenboost configuration
# Copy this file to .env and edit to match your system.
#
#   cp .env.example .env
#   vi .env
#   sudo ./setup.sh

# ── NVIDIA Driver ──────────────────────────────────────────────────────────────
# Driver branch to install.  Use "590" or newer.
# IMPORTANT: Must be the *proprietary* driver, NOT the open kernel module.
# The open module lacks cuMemHostRegister support on Turing (sm_75) GPUs.
NVIDIA_DRIVER_VERSION="590"

# "server" for headless machines, "desktop" if you need X11/Wayland.
NVIDIA_DRIVER_FLAVOR="server"

# ── GreenBoost ─────────────────────────────────────────────────────────────────
GREENBOOST_REPO="https://gitlab.com/IsolatedOctopi/nvidia_greenboost.git"
GREENBOOST_BRANCH="main"
GREENBOOST_INSTALL_DIR="/opt/greenboost"
GREENBOOST_SHIM_PATH="/usr/local/lib/libgreenboost_cuda.so"

# VRAM headroom (MB) kept free for CUDA internal bookkeeping.
GREENBOOST_VRAM_HEADROOM_MB="2048"

# Set to 1 to enable Path A (DMA-BUF kernel pinning).  Requires greenboost.ko.
# Set to 0 to fall back to Path B (HostReg without kernel module).
GREENBOOST_USE_DMA_BUF="1"

# ── vLLM ───────────────────────────────────────────────────────────────────────
VLLM_VERSION="0.18.0"
VLLM_VENV="/opt/vllm-env"

# ── Model ──────────────────────────────────────────────────────────────────────
# HuggingFace model ID and local download path.
MODEL_ID="Qwen/Qwen2.5-14B-Instruct"
MODEL_PATH="/opt/models/qwen2.5-14b-instruct"

# ── Serving ────────────────────────────────────────────────────────────────────
VLLM_HOST="0.0.0.0"
VLLM_PORT="8000"
VLLM_DTYPE="half"
VLLM_MAX_MODEL_LEN="2048"

# Fraction of *reported* VRAM to use.  GreenBoost inflates reported VRAM to
# include system RAM, so 0.95 would try to allocate more than physical RAM.
# Rule of thumb: (model_size_gb + kv_cache_gb) / reported_vram_gb
# For a 28 GB model on 16 GB GPU + 60 GB RAM → ~0.5
GPU_MEMORY_UTILIZATION="0.5"

# ── System ─────────────────────────────────────────────────────────────────────
VLLM_USER="vllm"
VLLM_GROUP="video"
